{
  "version": 2,
  "comment": "Vercel config for Al-Shalal Logistics. The Express API is deployed as a single serverless function; the React frontend is built to static files.",
  "builds": [
    {
      "src": "artifacts/al-shalal/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/public"
      }
    },
    {
      "src": "artifacts/api-server/src/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "artifacts/api-server/src/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "artifacts/al-shalal/dist/public/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
