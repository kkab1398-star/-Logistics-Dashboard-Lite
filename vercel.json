{
  "version": 2,
  "builds": [
    {
      "src": "artifacts/al-shalal/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "buildCommand": "pnpm --filter @workspace/al-shalal build",
  "installCommand": "npx pnpm@9 install --no-frozen-lockfile",
  "routes": [
    { "src": "/", "dest": "/dashboard" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
