{
  "version": 2,
  "buildCommand": "pnpm --filter @workspace/al-shalal build",
  "outputDirectory": "artifacts/al-shalal/dist/public",
  "installCommand": "npx pnpm@9 install --no-frozen-lockfile",
  "framework": null,
  "redirects": [
    { "source": "/", "destination": "/dashboard", "permanent": true }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}